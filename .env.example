# Скопіюй цей файл у .env і встав свої значення.
# .env НЕ комітимо (він у .gitignore) — там секрети.

# Токен Telegram-бота від @BotFather
BOT_TOKEN=

# LLM через OpenRouter (OpenAI-сумісний API). Ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Модель діалогу (обрана порівнянням). Можна будь-яку модель з OpenRouter.
LLM_MODEL=openai/gpt-4o-mini

# Модель faster-whisper для STT (small швидше, medium точніше)
WHISPER_MODEL=small

# Мова розпізнавання/синтезу: ru | uk
# Назва BOT_LANG (не LANG!), щоб не конфліктувати з системною локаллю LANG
BOT_LANG=ru

# Таймаут неактивної сесії, хвилин
SESSION_TIMEOUT_MIN=30

# STT через Groq Whisper API (опц.): якщо заданий — STT іде в хмару (швидше/точніше),
# інакше локальний faster-whisper. Ключ: https://console.groq.com
GROQ_API_KEY=
# GROQ_STT_MODEL=whisper-large-v3-turbo
